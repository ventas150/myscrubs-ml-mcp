# =====================================================================
# .env.example — Variables de entorno requeridas
# =====================================================================
# Copia este archivo como .env (local) o configúralas en Render dashboard.
# NUNCA commits el .env real al repo.

# ---------- MercadoLibre Developers ----------
ML_APP_ID=                       # Numérico, ej "1234567890"
ML_SECRET_KEY=                   # Secret de tu app ML
ML_REDIRECT_URI=https://myscrubs-ml-mcp.onrender.com/oauth/callback
ML_SITE_ID=MLC                   # MLC = Chile
ML_USER_ID_SELLER=               # Tu user_id de vendedor ML (numérico)
ML_MAIN_CATEGORIES=MLC1430
ML_MAIN_SEARCH_TERMS=uniforme clinico,uniforme medico,scrub mujer,scrub hombre,ambo clinico

# ---------- BSale ----------
BSALE_ACCESS_TOKEN=              # BSale > Configuración > API Acceso

# ---------- MCP HTTP server ----------
MCP_TRANSPORT=streamable-http
MCP_AUTH_TOKEN=                  # Bearer token compartido. Generá uno: `openssl rand -hex 32`
MCP_ALLOWED_ORIGINS=*
PORT=8000
HOST=0.0.0.0

# ---------- Storage ----------
MYSCRUBS_DATA_DIR=/var/data/myscrubs
ML_TOKENS_PATH=/var/data/myscrubs/tokens.json

# ---------- Profit Engine ----------
PROFIT_IVA_PCT=19
PROFIT_MIN_MARGIN_PCT=20
PROFIT_IDEAL_MARGIN_PCT=30
PROFIT_ENVIO_SUBSIDIO_CLP=1500

# ---------- Agente (guardrails) ----------
AGENT_MAX_CHANGE_PCT=10
AGENT_MAX_CHANGES_DAY=20
AGENT_PAUSE_DAYS=7
AGENT_AUTO_QUESTIONS=true

# ---------- Agente Claude ----------
ANTHROPIC_API_KEY=               # sk-ant-...
AGENT_MODE=daily_full            # daily_full | questions_sweep
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_TURNS=40
MCP_URL=https://myscrubs-ml-mcp.onrender.com/mcp

# ---------- Reportes (opcional) ----------
REPORT_EMAIL_TO=ventas@myscrubs.cl
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=                   # Gmail app password (no contraseña normal)
SMTP_FROM=noreply@myscrubs.cl
REPORT_WEBHOOK=                  # Opcional: URL para POST del JSON del reporte
